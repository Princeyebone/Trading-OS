# ─── API ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your_jwt_secret_key_here_change_this_in_production
FRONTEND_URL=http://localhost:5173

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to skip real broker connection (useful for testing without MT5)
BROKER_STUB_MODE=false
# Set to "true" to skip Telegram (useful for testing)
TELEGRAM_STUB_MODE=true
# News guard fail mode: "open" = allow trading when RSS unreachable (demo)
#                       "closed" = block trading when RSS unreachable (live)
NEWS_GUARD_FAIL_MODE=open
# Set to "true" to bypass the 20-minute candle staleness check.
# Use when running the engine outside market hours (weekends, holidays) for
# development/testing — the engine will process whatever data yfinance returns
# even if the latest candle is older than 20 minutes.
IGNORE_STALENESS=false
# Override the yfinance ticker symbol for pipeline testing with a different asset.
# Leave blank (default) to use the production symbol GC=F (Gold Futures).
# Examples: EURUSD=X (EUR/USD), SI=F (Silver), CL=F (Crude Oil)
FORCE_SYMBOL=
# Data feed mode: "yfinance" (demo/backfill) or "mt5" (live)
DATA_FEED_MODE=mt5


