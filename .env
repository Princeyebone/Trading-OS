# ─── Trading OS v2 — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://trading_user:your_secure_password@localhost:5432/trading_os

# ─── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_CHAT_ID=987654321

# ─── MetaTrader 5 ─────────────────────────────────────────────────────────────
MT5_LOGIN=12345678
MT5_PASSWORD=your_mt5_password
MT5_SERVER=YourBroker-Demo

# ─── Engine Configuration ─────────────────────────────────────────────────────
ACCOUNT_BALANCE_EQUIV=500
MAX_RISK_PERCENT=1.0
MAX_TRADES_PER_DAY=2
CONFIDENCE_THRESHOLD=70
MIN_ATR_PERCENTILE=20

# ─── API ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your_jwt_secret_key_here_change_this_in_production
FRONTEND_URL=http://localhost:5173

# ─── Feature Flags ────────────────────────────────────────────────────────────
# Set to "true" to skip real broker connection (useful for testing without MT5)
BROKER_STUB_MODE=false
# Set to "true" to skip Telegram (useful for testing)
TELEGRAM_STUB_MODE=false
